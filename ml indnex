<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover,user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="CTA">
<meta name="theme-color" content="#0A0A0B">
<link rel="apple-touch-icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 180 180'%3E%3Crect width='180' height='180' rx='40' fill='%230A0A0B'/%3E%3Ccircle cx='90' cy='90' r='52' fill='none' stroke='%2300D26A' stroke-width='10'/%3E%3Ctext x='90' y='106' font-family='-apple-system,Arial,sans-serif' font-size='46' font-weight='800' text-anchor='middle' fill='%23F5F4F0'%3ECTA%3C/text%3E%3C/svg%3E">
<title>CTA · ¿Conviene?</title>
<style>
:root{
  --bg:       #0A0A0B;
  --surf:     #15151A;
  --surf2:    #1C1C22;
  --line:     rgba(255,255,255,.08);
  --line2:    rgba(255,255,255,.14);
  --ink:      #F5F4F0;
  --ink2:     rgba(245,244,240,.55);
  --ink3:     rgba(245,244,240,.32);
  --go:       #00D26A;
  --go-dim:   rgba(0,210,106,.12);
  --no:       #FF4757;
  --no-dim:   rgba(255,71,87,.12);
  --warn:     #FFB020;
  --warn-dim: rgba(255,176,32,.12);
  --safe-t:   env(safe-area-inset-top,44px);
  --safe-b:   env(safe-area-inset-bottom,0px);
  --sans:     -apple-system,'SF Pro Text',Helvetica,sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;background:var(--bg);}
body{
  font-family:var(--sans);color:var(--ink);
  -webkit-font-smoothing:antialiased;overflow:hidden;height:100dvh;
  font-size:15px;line-height:1.4;
}
input,select,button{font-family:var(--sans);-webkit-appearance:none;}
input:focus,select:focus{outline:none;}
button{cursor:pointer;border:none;background:none;}
::-webkit-scrollbar{display:none;}

/* ═══════ SHELL ═══════ */
.app{display:flex;flex-direction:column;height:100dvh;background:var(--bg);}

.hdr{
  padding-top:var(--safe-t);
  flex-shrink:0;background:var(--bg);
  border-bottom:1px solid var(--line);
}
.hdr-row{
  display:flex;align-items:center;justify-content:space-between;
  padding:14px 18px 14px;
}
.hdr-title{font-size:17px;font-weight:800;letter-spacing:-.02em;}
.hdr-title b{color:var(--go);}
.hdr-icon{
  width:34px;height:34px;border-radius:10px;
  background:var(--surf);
  display:flex;align-items:center;justify-content:center;
  font-size:16px;color:var(--ink2);
}

.scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;overscroll-behavior:contain;}

.tabbar{
  flex-shrink:0;display:flex;
  padding:8px 8px calc(var(--safe-b) + 8px);
  background:var(--bg);border-top:1px solid var(--line);
  gap:4px;
}
.tab{
  flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;
  padding:6px 0;border-radius:12px;transition:background .15s;
}
.tab-ic{font-size:19px;opacity:.35;transition:opacity .15s;}
.tab-lb{font-size:10px;font-weight:600;color:var(--ink3);letter-spacing:.02em;transition:color .15s;}
.tab.on .tab-ic{opacity:1;}
.tab.on .tab-lb{color:var(--ink);}

.pane{display:none;}
.pane.on{display:block;}

/* ═══════ ANALYZER — single screen, all that matters ═══════ */
.an-wrap{padding:18px 18px 28px;display:flex;flex-direction:column;gap:14px;}

/* Result ring + verdict — THE signature element */
.ring-card{
  background:var(--surf);border:1px solid var(--line);
  border-radius:24px;padding:24px 20px 22px;
  display:flex;flex-direction:column;align-items:center;
  transition:border-color .3s;
}
.ring-card.go{border-color:rgba(0,210,106,.35);}
.ring-card.no{border-color:rgba(255,71,87,.35);}
.ring-card.warn{border-color:rgba(255,176,32,.35);}

.ring-box{position:relative;width:172px;height:172px;margin-bottom:14px;}
.ring-svg{width:100%;height:100%;transform:rotate(-90deg);}
.ring-bg{fill:none;stroke:var(--surf2);stroke-width:14;}
.ring-fg{fill:none;stroke-width:14;stroke-linecap:round;
  transition:stroke-dasharray .55s cubic-bezier(.4,0,.2,1),stroke .3s;}
.ring-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.ring-num{font-size:38px;font-weight:800;letter-spacing:-.04em;font-variant-numeric:tabular-nums;line-height:1;}
.ring-lbl{font-size:10px;font-weight:700;color:var(--ink3);text-transform:uppercase;letter-spacing:.1em;margin-top:3px;}

.verdict-pill{
  display:flex;align-items:center;gap:7px;
  padding:8px 16px;border-radius:20px;
  font-size:14px;font-weight:800;letter-spacing:-.01em;
  margin-bottom:4px;
}
.vp-go{background:var(--go-dim);color:var(--go);}
.vp-no{background:var(--no-dim);color:var(--no);}
.vp-warn{background:var(--warn-dim);color:var(--warn);}
.vp-empty{background:var(--surf2);color:var(--ink3);}
.verdict-sub{font-size:12px;color:var(--ink2);text-align:center;line-height:1.4;}

/* Big utility number row */
.util-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.util-cell{
  background:var(--surf);border:1px solid var(--line);
  border-radius:16px;padding:14px 16px;
}
.util-lbl{font-size:10px;font-weight:700;color:var(--ink3);text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px;}
.util-val{font-size:21px;font-weight:800;letter-spacing:-.03em;font-variant-numeric:tabular-nums;}
.util-sub{font-size:11px;color:var(--ink3);margin-top:3px;}
.u-go{color:var(--go);}
.u-no{color:var(--no);}

/* Mode toggle */
.mode-toggle{
  display:flex;background:var(--surf);border:1px solid var(--line);
  border-radius:14px;padding:4px;gap:4px;
}
.mode-btn{
  flex:1;padding:10px 0;border-radius:10px;
  font-size:13px;font-weight:700;color:var(--ink3);
  text-align:center;transition:all .15s;
}
.mode-btn.on{background:var(--surf2);color:var(--ink);}

/* Calculated price card (reverse mode) */
.calc-price-card{
  background:var(--go-dim);border:1px solid rgba(0,210,106,.3);
  border-radius:16px;padding:18px 16px;text-align:center;
}
.cpc-lbl{font-size:11px;font-weight:800;color:var(--go);text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px;}
.cpc-val{font-size:34px;font-weight:800;color:var(--go);letter-spacing:-.03em;font-variant-numeric:tabular-nums;margin-bottom:6px;}
.cpc-sub{font-size:11px;color:var(--ink2);line-height:1.5;max-width:260px;margin:0 auto;}

/* Section label */
.sec-lbl{
  font-size:11px;font-weight:800;color:var(--ink3);
  text-transform:uppercase;letter-spacing:.1em;
  padding:4px 2px 2px;
}

/* Input cards */
.field-card{
  background:var(--surf);border:1px solid var(--line);
  border-radius:16px;overflow:hidden;
}
.field-row{
  display:flex;align-items:center;justify-content:space-between;
  padding:13px 16px;border-bottom:1px solid var(--line);
  gap:10px;
}
.field-row:last-child{border-bottom:none;}
.field-row.readonly{background:rgba(255,176,32,.04);}
.fr-label{font-size:14px;color:var(--ink2);flex-shrink:0;}
.fr-label .auto{font-size:9px;font-weight:800;color:var(--warn);margin-left:5px;letter-spacing:.04em;}
.fr-input{
  font-size:17px;font-weight:700;color:var(--ink);
  background:none;border:none;text-align:right;
  flex:1;min-width:0;font-variant-numeric:tabular-nums;
}
.fr-input::placeholder{color:var(--ink3);font-weight:400;}
.fr-input.ro{color:var(--warn);}
.fr-select{
  font-size:15px;font-weight:700;color:var(--ink);
  background:none;border:none;text-align:right;
}
.fr-select option{background:var(--surf2);}
.fr-unit{font-size:11px;color:var(--ink3);margin-left:4px;}

/* Toggle */
.tog-row{
  display:flex;align-items:center;justify-content:space-between;
  padding:13px 16px;
}
.tog-label{font-size:14px;color:var(--ink2);}
.sw{position:relative;width:44px;height:26px;flex-shrink:0;}
.sw input{opacity:0;width:0;height:0;}
.sw-t{position:absolute;inset:0;border-radius:13px;background:var(--surf2);transition:.2s;}
.sw input:checked+.sw-t{background:var(--go);}
.sw-k{position:absolute;top:2px;left:2px;width:22px;height:22px;border-radius:50%;background:#fff;
  box-shadow:0 1px 3px rgba(0,0,0,.4);transition:.2s cubic-bezier(.34,1.4,.64,1);}
.sw input:checked~.sw-k{transform:translateX(18px);}

/* Rotation gauge */
.rot-card{
  background:var(--surf);border:1px solid var(--line);
  border-radius:16px;padding:16px;
}
.rot-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:11px;}
.rot-title{font-size:13px;font-weight:700;color:var(--ink);}
.rot-tag{font-size:10px;font-weight:800;padding:3px 10px;border-radius:20px;letter-spacing:.02em;}
.rt-go{background:var(--go-dim);color:var(--go);}
.rt-warn{background:var(--warn-dim);color:var(--warn);}
.rt-no{background:var(--no-dim);color:var(--no);}
.rt-empty{background:var(--surf2);color:var(--ink3);}
.rot-track{height:8px;background:var(--surf2);border-radius:4px;overflow:hidden;margin-bottom:9px;}
.rot-fill{height:100%;border-radius:4px;transition:width .5s cubic-bezier(.4,0,.2,1),background .3s;}
.rot-foot{display:flex;justify-content:space-between;font-size:12px;color:var(--ink3);}
.rot-days{font-weight:700;font-variant-numeric:tabular-nums;color:var(--ink);}

/* Breakdown */
.bk-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:11px 16px;border-bottom:1px solid var(--line);font-size:14px;
}
.bk-row:last-child{border-bottom:none;}
.bk-k{color:var(--ink2);}
.bk-v{font-weight:700;font-variant-numeric:tabular-nums;}
.bk-v.minus{color:var(--no);}
.bk-row.mid{background:rgba(255,255,255,.02);}
.bk-row.mid .bk-k{font-weight:700;color:var(--ink);}
.bk-row.total{background:rgba(255,255,255,.03);}
.bk-row.total .bk-k{font-weight:800;font-size:15px;color:var(--ink);}
.bk-row.total .bk-v{font-size:17px;font-weight:800;}

/* Distribution bar */
.dist-card{background:var(--surf);border:1px solid var(--line);border-radius:16px;padding:16px;}
.dist-track{height:34px;display:flex;border-radius:9px;overflow:hidden;background:var(--surf2);gap:1px;margin-bottom:11px;}
.dist-seg{height:100%;display:flex;align-items:center;justify-content:center;overflow:hidden;transition:width .45s cubic-bezier(.4,0,.2,1);}
.dist-seg-lbl{font-size:9px;font-weight:800;color:rgba(0,0,0,.7);white-space:nowrap;padding:0 5px;}
.dist-leg{display:flex;flex-wrap:wrap;gap:9px;}
.dl-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--ink2);}
.dl-sq{width:8px;height:8px;border-radius:2px;flex-shrink:0;}

/* Price min callout */
.pmin-card{
  background:var(--go-dim);border:1px solid rgba(0,210,106,.3);
  border-radius:16px;padding:15px 16px;
  display:flex;justify-content:space-between;align-items:center;
}
.pmin-lbl{font-size:10px;font-weight:800;color:var(--go);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px;}
.pmin-val{font-size:24px;font-weight:800;color:var(--go);letter-spacing:-.03em;font-variant-numeric:tabular-nums;}
.pmin-sub{font-size:11px;color:var(--ink2);margin-top:3px;}

/* Action buttons */
.act-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.act-btn{
  padding:15px;border-radius:14px;font-size:14px;font-weight:800;
  text-align:center;letter-spacing:-.01em;transition:opacity .1s;
}
.act-btn:active{opacity:.75;}
.act-go{background:var(--go);color:#001a0d;}
.act-no{background:var(--no-dim);color:var(--no);border:1px solid rgba(255,71,87,.25);}
.btn-clear{
  width:100%;padding:13px;border-radius:14px;
  background:var(--surf);border:1px solid var(--line);
  color:var(--ink2);font-size:13px;font-weight:700;text-align:center;
}
.btn-clear:active{opacity:.7;}

/* Empty state for ring */
.ring-empty-msg{font-size:12px;color:var(--ink3);text-align:center;line-height:1.5;max-width:200px;}

/* ═══════ HISTORIAL ═══════ */
.h-wrap{padding:14px 18px 24px;}
.h-search-row{display:flex;gap:8px;margin-bottom:14px;}
.h-search{
  flex:1;background:var(--surf);border:1px solid var(--line);
  border-radius:12px;padding:11px 14px;font-size:15px;color:var(--ink);
}
.h-search::placeholder{color:var(--ink3);}
.h-filter{
  background:var(--surf);border:1px solid var(--line);
  border-radius:12px;padding:11px 12px;font-size:13px;color:var(--ink);
}
.h-filter option{background:var(--surf2);}

.h-card{
  background:var(--surf);border:1px solid var(--line);
  border-radius:16px;margin-bottom:10px;overflow:hidden;
}
.h-bar{height:4px;display:flex;}
.h-bar-seg{height:100%;transition:width .3s;}
.h-body{padding:13px 15px;}
.h-name{font-size:15px;font-weight:700;margin-bottom:7px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.h-row{display:flex;justify-content:space-between;align-items:flex-end;}
.h-chips{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:5px;}
.h-chip{font-size:10px;font-weight:800;padding:3px 9px;border-radius:20px;}
.hc-go{background:var(--go-dim);color:var(--go);}
.hc-no{background:var(--no-dim);color:var(--no);}
.hc-warn{background:var(--warn-dim);color:var(--warn);}
.hc-n{background:var(--surf2);color:var(--ink3);}
.h-num{font-size:19px;font-weight:800;letter-spacing:-.02em;font-variant-numeric:tabular-nums;}
.h-margin{font-size:11px;color:var(--ink3);margin-top:2px;}
.h-actions{display:flex;border-top:1px solid var(--line);}
.h-act{flex:1;padding:11px;text-align:center;font-size:12px;font-weight:700;color:var(--ink3);}
.h-act:active{color:var(--ink);}
.h-act-del{color:rgba(255,71,87,.45);}
.h-sep{width:1px;background:var(--line);}

.empty-state{padding:60px 30px;text-align:center;}
.es-icon{font-size:40px;opacity:.25;margin-bottom:12px;}
.es-txt{font-size:14px;color:var(--ink3);line-height:1.5;}

.csv-export-btn{
  display:block;width:100%;margin-top:16px;padding:13px;
  border-radius:14px;background:var(--surf);border:1px solid var(--line);
  color:var(--ink3);font-size:12px;font-weight:600;text-align:center;
}
.csv-export-btn:active{opacity:.7;color:var(--ink2);}

/* ═══════ CONFIG SHEET ═══════ */
.overlay{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.6);backdrop-filter:blur(6px);display:flex;align-items:flex-end;}
.overlay.hidden{display:none!important;}
.sheet{background:var(--surf);border-radius:24px 24px 0 0;width:100%;max-height:88dvh;overflow-y:auto;border-top:1px solid var(--line2);}
.sheet-handle{width:36px;height:5px;background:var(--surf2);border-radius:3px;margin:12px auto 16px;}
.sheet-title{font-size:18px;font-weight:800;padding:0 20px 14px;letter-spacing:-.02em;}
.cfg-sec-lbl{font-size:11px;font-weight:800;color:var(--ink3);text-transform:uppercase;letter-spacing:.09em;padding:16px 20px 8px;}
.cfg-list{padding:0 20px;display:flex;flex-direction:column;gap:8px;}
.cfg-row{display:flex;justify-content:space-between;align-items:center;background:var(--surf2);border-radius:12px;padding:13px 15px;}
.cfg-lbl{font-size:14px;color:var(--ink2);}
.cfg-inp{width:78px;text-align:right;font-size:16px;font-weight:700;background:none;border:none;color:var(--ink);font-variant-numeric:tabular-nums;}
.cfg-save{display:block;width:calc(100% - 40px);margin:18px 20px 0;padding:15px;border-radius:14px;background:var(--go);color:#001a0d;font-size:15px;font-weight:800;text-align:center;}
.cfg-save:active{opacity:.8;}
.cfg-note{margin:14px 20px 0;padding:12px 14px;background:var(--surf2);border-radius:12px;font-size:12px;color:var(--ink2);line-height:1.5;}
.cfg-note b{color:var(--go);}

#toast{
  position:fixed;bottom:calc(var(--safe-b) + 78px);left:50%;
  transform:translateX(-50%) translateY(14px);
  background:var(--surf2);border:1px solid var(--line2);color:var(--ink);
  padding:11px 22px;border-radius:24px;font-size:13px;font-weight:700;
  white-space:nowrap;opacity:0;transition:all .22s cubic-bezier(.34,1.3,.64,1);
  z-index:999;pointer-events:none;
}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.hidden{display:none!important;}
</style>
</head>
<body>
<div class="app">

  <div class="hdr">
    <div class="hdr-row">
      <div class="hdr-title">CTA · <b>¿Conviene?</b></div>
      <div class="hdr-icon" onclick="openCfg()">⚙</div>
    </div>
  </div>

  <div class="scroll" id="scroll">

    <!-- ══════════ ANALIZADOR ══════════ -->
    <div class="pane on" id="p-an">
      <div class="an-wrap">

        <!-- RESULT RING -->
        <div class="ring-card" id="ringCard">
          <div class="ring-box">
            <svg class="ring-svg" viewBox="0 0 172 172">
              <circle cx="86" cy="86" r="73" class="ring-bg"/>
              <circle cx="86" cy="86" r="73" class="ring-fg" id="ringFg" stroke-dasharray="0 459"/>
            </svg>
            <div class="ring-center">
              <div class="ring-num" id="ringNum">—</div>
              <div class="ring-lbl">margen</div>
            </div>
          </div>
          <div class="verdict-pill vp-empty" id="verdictPill">Esperando datos</div>
          <div class="verdict-sub" id="verdictSub">Completa precio y costo para ver si conviene</div>
        </div>

        <!-- UTILITY -->
        <div class="util-row">
          <div class="util-cell">
            <div class="util-lbl">Utilidad / pieza</div>
            <div class="util-val" id="uPza">—</div>
          </div>
          <div class="util-cell">
            <div class="util-lbl">Utilidad total</div>
            <div class="util-val" id="uTotal">—</div>
            <div class="util-sub" id="uTotalSub"></div>
          </div>
        </div>

        <!-- MODO -->
        <div class="mode-toggle" id="modeToggle">
          <button class="mode-btn on" id="mbForward" onclick="setMode('forward')">Tengo el precio</button>
          <button class="mode-btn" id="mbReverse" onclick="setMode('reverse')">Calcular precio</button>
        </div>

        <!-- PRECIO Y TIPO -->
        <div class="sec-lbl">El producto</div>
        <div class="field-card">
          <div class="field-row">
            <span class="fr-label">Nombre</span>
            <input class="fr-input" type="text" id="fNombre" placeholder="Philips Avent Set..." style="text-align:right;font-size:15px;font-weight:600">
          </div>
          <div class="field-row" id="rowPrecio">
            <span class="fr-label">Precio de venta</span>
            <input class="fr-input" type="number" id="fPrecio" placeholder="0" inputmode="decimal" oninput="onInput()">
            <span class="fr-unit">MXN</span>
          </div>
          <div class="field-row hidden" id="rowMargenDeseado">
            <span class="fr-label">Margen deseado</span>
            <input class="fr-input" type="number" id="fMargenDeseado" placeholder="20" inputmode="decimal" oninput="onInput()">
            <span class="fr-unit">%</span>
          </div>
          <div class="field-row">
            <span class="fr-label">Publicación</span>
            <select class="fr-select" id="fTipo" onchange="onInput()">
              <option value="C">Clásica · 15%</option>
              <option value="P">Premium · 19.5%</option>
            </select>
          </div>
        </div>

        <!-- PRECIO CALCULADO (solo modo inverso) -->
        <div class="calc-price-card hidden" id="calcPriceCard">
          <div class="cpc-lbl">Precio de venta necesario</div>
          <div class="cpc-val" id="cpcVal">—</div>
          <div class="cpc-sub">Para lograr el margen que pediste, después de comisión, impuesto, envío y costo</div>
        </div>

        <!-- GASTOS -->
        <div class="sec-lbl">Gastos de Mercado Libre</div>
        <div class="field-card">
          <div class="field-row readonly">
            <span class="fr-label">Comisión<span class="auto">AUTO</span></span>
            <input class="fr-input ro" type="number" id="fCom" placeholder="0" readonly>
          </div>
          <div class="field-row readonly">
            <span class="fr-label">Impuesto 10.5%<span class="auto">AUTO</span></span>
            <input class="fr-input ro" type="number" id="fImp" placeholder="0" readonly>
          </div>
          <div class="field-row">

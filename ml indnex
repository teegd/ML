<script>
// ═══════════════════════════════════════════
// STORE
// ═══════════════════════════════════════════
const DK='ctaP_d', CK='ctaP_c';
const load = () => { try { return JSON.parse(localStorage.getItem(DK)) || []; } catch { return []; } };
const dump = d => localStorage.setItem(DK, JSON.stringify(d));
const getCfg = () => {
  const D = { clasica:15, premium:19.5, tarjeta:7, margenMin:20, dias:60 };
  try { return { ...D, ...JSON.parse(localStorage.getItem(CK)) }; } catch { return D; }
};

// ═══════════════════════════════════════════
// CALC
// ═══════════════════════════════════════════
function calc(precio, com, imp, envio, costo, uds, v60, tarjeta, cfg) {
  if (!precio || !costo) return null;
  const ingNeto    = precio - com - imp - envio;
  const costoFin   = tarjeta ? costo * (cfg.tarjeta/100) : 0;
  const costoReal  = costo + costoFin;
  const utilPza    = ingNeto - costoReal;
  const margen     = precio > 0 ? utilPza/precio : 0;
  const utilTotal  = utilPza * (uds||0);
  const costoTotal = costoReal * (uds||0);
  const roi        = costoTotal > 0 ? utilTotal/costoTotal : 0;
  const dias       = (v60 > 0 && uds > 0) ? Math.ceil(uds * cfg.dias / v60) : null;
  const comR = precio>0 ? com/precio : 0, impR = precio>0 ? imp/precio : 0;
  const den  = 1 - comR - impR;
  const pmin = den > cfg.margenMin/100 ? (costoReal+envio)/(den-cfg.margenMin/100) : null;
  return { ingNeto, costoFin, costoReal, utilPza, margen, utilTotal, costoTotal, roi, dias, pmin };
}

function verdict(R, cfg) {
  if (!R) return { cls:'vp-empty', txt:'Esperando datos', sub:'Completa precio y costo para ver si conviene', ring:'no-data' };
  const mOk  = R.margen >= cfg.margenMin/100;
  const dOk  = R.dias === null || R.dias <= cfg.dias;
  const dKnd = R.dias === null || R.dias <= cfg.dias*2;
  if (mOk && dOk)   return { cls:'vp-go',   txt:'✓ Conviene invertir',     sub:'Buen margen y rotación saludable', ring:'go' };
  if (mOk && dKnd)  return { cls:'vp-go',   txt:'✓ Conviene',
